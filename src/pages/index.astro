---
import Layout from "../layouts/Layout.astro";
---

<Layout title="AZea Labs | Software & QA Automation Ecosystem">
  <main class="min-h-screen">
    <section class="relative overflow-hidden border-b border-white/10">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(59,130,246,0.25),transparent_35%),radial-gradient(circle_at_top_left,rgba(14,165,233,0.16),transparent_30%)]"></div>

      <div class="relative mx-auto flex min-h-screen max-w-6xl flex-col px-6 py-8">
        <header class="flex items-center justify-between">
          <a href="/" class="text-lg font-bold tracking-tight">
            AZea<span class="text-sky-400">Labs</span>
          </a>

          <nav class="hidden items-center gap-6 text-sm text-slate-300 md:flex">
            <a href="#about" class="hover:text-white">About</a>
            <a href="#projects" class="hover:text-white">Projects</a>
            <a href="#contact" class="hover:text-white">Contact</a>
          </nav>
        </header>

        <div class="flex flex-1 items-center">
          <div class="max-w-3xl">
            <p class="mb-5 inline-flex rounded-full border border-sky-400/30 bg-sky-400/10 px-4 py-2 text-sm font-medium text-sky-300">
              Software Development · QA Automation · Technical Learning
            </p>

            <h1 class="text-5xl font-bold tracking-tight text-white md:text-7xl">
              Building software to learn, automate, and teach better.
            </h1>

            <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300">
              AZea Labs is a software and QA automation ecosystem created by
              Antonio Zea. The goal is to build real projects, improve
              development and architecture skills, and create practical tools
              for automation learning.
            </p>

            <div class="mt-10 flex flex-col gap-4 sm:flex-row">
              <a
                href="#projects"
                class="rounded-lg bg-sky-400 px-6 py-3 text-center text-sm font-semibold text-slate-950 transition hover:bg-sky-300"
              >
                View projects
              </a>

              <a
                href="#contact"
                class="rounded-lg border border-white/15 px-6 py-3 text-center text-sm font-semibold text-white transition hover:bg-white/10"
              >
                Contact
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="about" class="mx-auto max-w-6xl px-6 py-24">
      <div class="grid gap-10 md:grid-cols-[0.9fr_1.1fr]">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-400">
            About
          </p>
          <h2 class="mt-4 text-3xl font-bold text-white md:text-4xl">
            A portfolio that will grow into a complete QA automation ecosystem.
          </h2>
        </div>

        <div class="space-y-5 text-slate-300">
          <p>
            AZea Labs starts as a professional portfolio, but the long-term
            vision is bigger: a connected ecosystem of projects focused on
            QA automation, software development, APIs, architecture, and future
            educational products.
          </p>

          <p>
            The first major product will be QA Labs, a platform designed to
            practice automation with tools like Selenium, Cypress, Playwright,
            Robot Framework, and API testing tools.
          </p>
        </div>
      </div>
    </section>

    <section id="projects" class="border-y border-white/10 bg-white/[0.03]">
      <div class="mx-auto max-w-6xl px-6 py-24">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-400">
          Projects
        </p>

        <h2 class="mt-4 max-w-3xl text-3xl font-bold text-white md:text-4xl">
          Products planned under the AZea Labs ecosystem.
        </h2>

        <div class="mt-12 grid gap-6 md:grid-cols-3">
          <article class="rounded-2xl border border-white/10 bg-slate-900/70 p-6">
            <h3 class="text-xl font-bold text-white">Portfolio</h3>
            <p class="mt-4 text-sm leading-6 text-slate-300">
              The main professional hub for Antonio Zea, technical projects,
              blog posts, and future products.
            </p>
            <p class="mt-6 text-sm font-medium text-sky-300">In progress</p>
          </article>

          <article class="rounded-2xl border border-white/10 bg-slate-900/70 p-6">
            <h3 class="text-xl font-bold text-white">QA Labs</h3>
            <p class="mt-4 text-sm leading-6 text-slate-300">
              A future practice platform with web pages, APIs, and real testing
              scenarios for automation engineers.
            </p>
            <p class="mt-6 text-sm font-medium text-sky-300">Coming next</p>
          </article>

          <article class="rounded-2xl border border-white/10 bg-slate-900/70 p-6">
            <h3 class="text-xl font-bold text-white">QA Academy</h3>
            <p class="mt-4 text-sm leading-6 text-slate-300">
              A future educational platform focused on teaching QA automation
              using QA Labs as the practice environment.
            </p>
            <p class="mt-6 text-sm font-medium text-sky-300">Future phase</p>
          </article>
        </div>
      </div>
    </section>

    <section id="contact" class="mx-auto max-w-6xl px-6 py-24">
      <div class="rounded-3xl border border-white/10 bg-slate-900/80 p-8 md:p-12">
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-sky-400">
          Contact
        </p>

        <h2 class="mt-4 text-3xl font-bold text-white md:text-4xl">
          Let’s build, automate, and learn.
        </h2>

        <p class="mt-5 max-w-2xl text-slate-300">
          This is the first public version of AZea Labs. More projects,
          documentation, automation examples, and technical content will be
          added over time.
        </p>

        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a
            href="https://github.com/azealabs"
            target="_blank"
            rel="noreferrer"
            class="rounded-lg bg-white px-6 py-3 text-center text-sm font-semibold text-slate-950 transition hover:bg-slate-200"
          >
            GitHub
          </a>

          <a
            href="mailto:hello@azealabs.com"
            class="rounded-lg border border-white/15 px-6 py-3 text-center text-sm font-semibold text-white transition hover:bg-white/10"
          >
            Email
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>